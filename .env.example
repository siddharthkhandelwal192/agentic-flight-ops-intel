# Copy to .env locally. Never commit real secrets.

# Service
ENV=local
LOG_LEVEL=INFO
SERVICE_NAME=afois-api

API_HOST=0.0.0.0
API_PORT=8000
# Browser origins allowed to call the API (comma-separated). Add your deployed Next.js URL in prod.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Allow any localhost / 127.0.0.1 port via regex (set false in strict production).
CORS_ALLOW_LOCALHOST_REGEX=true

# PostgreSQL — default quickstart keeps SQLite locally; Compose sets Postgres URL internally.
DATABASE_URL=sqlite:///./data/afois_local.db

# OpenAI (chat + embeddings)
# Primary: openai (recommended for reliable live `/v1/llm/chat`). Keep GEMINI_API_KEY for failover when LLM_AUTO_FAILOVER=true.
LLM_PROVIDER=openai
LLM_AUTO_FAILOVER=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Gemini (native google-generativeai + LangChain Google GenAI — not OpenAI-compatible)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest
# Optional: try this model if primary hits quota (native API /chat only)
# GEMINI_FALLBACK_MODEL=gemini-1.5-flash
# Optional DEMO ONLY: return 200 on hard rate limits (hides real 429 — leave unset for production)
# LLM_RATE_LIMIT_FALLBACK_REPLY=
EMBEDDING_PROVIDER=auto
LOCAL_EMBEDDING_DIMENSIONS=256
LLM_REQUEST_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2
# OPENAI_BASE_URL=https://api.openai.com/v1

# Chroma persisted directory (mounted in Compose to /data/chroma_db)
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
CHROMA_COLLECTION_NAME=afois_policy_docs

# LangSmith tracing (LANGCHAIN_* env wired in code at startup when enabled)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=afois
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Dangerous corpus rebuild endpoint — set locally if you expose /v1/rag/rebuild publicly
ADMIN_REINDEX_TOKEN=
