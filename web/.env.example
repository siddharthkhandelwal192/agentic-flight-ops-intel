# --- Backend target for Next.js rewrites (SERVER-SIDE only, read by next.config.ts) ---
# Browser calls go to SAME ORIGIN `/afois-api/*`; Next proxies to this URL.
# Docker `web` service: use http://api:8000
AFOIS_BACKEND_URL=http://127.0.0.1:8000

# Optional alias (same as AFOIS_BACKEND_URL)
# BACKEND_URL=http://127.0.0.1:8000

# --- Do NOT set for local dev ---
# NEXT_PUBLIC_* is inlined at build/start. A value here makes the OLD client call :8000
# directly and often shows "Failed to fetch". We removed that path from code — leave unset.
