{
  "info": {
    "name": "AFOIS - Agentic Flight Operations Intelligence System",
    "description": "FastAPI multi-agent LLM backend with RAG, LangGraph, and SQL tools",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "DB Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/ops/db-health",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "ops", "db-health"]
        }
      }
    },
    {
      "name": "List Flights",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/ops/flights?airline_code=UA",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "ops", "flights"],
          "query": [{"key": "airline_code", "value": "UA"}]
        }
      }
    },
    {
      "name": "OpenAI Chat",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {
          "raw": "{{baseUrl}}/v1/llm/chat",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "llm", "chat"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": [\n    {\"role\": \"system\", \"content\": \"You are a concise OCC analyst.\"},\n    {\"role\": \"user\", \"content\": \"Outline a 3-bullet gate brief for ORD weather risk.\"}\n  ],\n  \"temperature\": 0.2\n}",
          "options": {"raw": {"language": "json"}}
        }
      }
    },
    {
      "name": "Operations Agent - Delay Query",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {
          "raw": "{{baseUrl}}/v1/llm/agents/operations",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "llm", "agents", "operations"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": [\n    {\"role\": \"user\", \"content\": \"Summarize recent delay attributions and mention crew-related cases.\"}\n  ]\n}",
          "options": {"raw": {"language": "json"}}
        }
      }
    },
    {
      "name": "Operations Agent - Policy Query",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {
          "raw": "{{baseUrl}}/v1/llm/agents/operations",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "llm", "agents", "operations"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"messages\": [\n    {\"role\": \"user\", \"content\": \"What does policy say about minimum connection times for international itineraries?\"}\n  ]\n}",
          "options": {"raw": {"language": "json"}}
        }
      }
    },
    {
      "name": "RAG Search",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/rag/search?q=connection%20time&top_k=3",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "rag", "search"],
          "query": [
            {"key": "q", "value": "connection time"},
            {"key": "top_k", "value": "3"}
          ]
        }
      }
    },
    {
      "name": "RAG Rebuild (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "X-Admin-Token", "value": "{{adminToken}}"}
        ],
        "url": {
          "raw": "{{baseUrl}}/v1/rag/rebuild",
          "host": ["{{baseUrl}}"],
          "path": ["v1", "rag", "rebuild"]
        }
      }
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8000", "type": "string"},
    {"key": "adminToken", "value": "change-me", "type": "string"}
  ]
}
